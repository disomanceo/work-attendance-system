import { NextResponse } from "next/server";
import { createClient } from "@supabase/supabase-js";

export const dynamic = "force-dynamic";

type Profile = {
  id: string;
  full_name: string;
  role: string;
  account_status: string;
  work_permissions: string[] | null;
};

const PAYMENT_SELECT = `
  id,
  project_id,
  project_name,
  details,
  payment_period,
  amount,
  evidence_name,
  evidence_path,
  note,
  status,
  created_at,
  created_by,
  created_by_name,
  updated_at,
  cancelled_at,
  cancelled_by,
  cancelled_by_name
`;

function config() {
  const url = process.env.NEXT_PUBLIC_SUPABASE_URL;
  const publishableKey = process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY;
  const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;

  if (!url || !publishableKey || !serviceRoleKey) return null;
  return { url, publishableKey, serviceRoleKey };
}

function accessToken(request: Request) {
  const value = request.headers.get("authorization") ?? "";
  return value.startsWith("Bearer ")
    ? value.slice("Bearer ".length).trim()
    : "";
}

async function requireActiveUser(request: Request) {
  const env = config();

  if (!env) {
    return {
      ok: false as const,
      response: NextResponse.json(
        { ok: false, message: "ยังตั้งค่า Supabase ฝั่ง Server ไม่ครบ" },
        { status: 500 }
      ),
    };
  }

  const token = accessToken(request);

  if (!token) {
    return {
      ok: false as const,
      response: NextResponse.json(
        { ok: false, message: "กรุณาเข้าสู่ระบบใหม่" },
        { status: 401 }
      ),
    };
  }

  const authClient = createClient(env.url, env.publishableKey, {
    auth: { autoRefreshToken: false, persistSession: false },
  });

  const {
    data: { user },
    error: userError,
  } = await authClient.auth.getUser(token);

  if (userError || !user) {
    return {
      ok: false as const,
      response: NextResponse.json(
        { ok: false, message: "Session หมดอายุ กรุณาเข้าสู่ระบบใหม่" },
        { status: 401 }
      ),
    };
  }

  const adminClient = createClient(env.url, env.serviceRoleKey, {
    auth: { autoRefreshToken: false, persistSession: false },
  });

  const { data, error } = await adminClient
    .from("profiles")
    .select("id, full_name, role, account_status, work_permissions")
    .eq("id", user.id)
    .maybeSingle();

  const profile = data as Profile | null;

  if (error || !profile || profile.account_status !== "active") {
    return {
      ok: false as const,
      response: NextResponse.json(
        { ok: false, message: "บัญชีผู้ใช้ยังไม่พร้อมใช้งาน" },
        { status: 403 }
      ),
    };
  }

  const elevated = ["admin", "director"].includes(profile.role);
  const permissions = Array.isArray(profile.work_permissions)
    ? profile.work_permissions
    : [];

  return {
    ok: true as const,
    adminClient,
    profile,
    canManageAll: elevated,
    canFinance: elevated || permissions.includes("budget.finance"),
  };
}

function fileExtension(name: string) {
  const cleanName = name.trim();
  const dotIndex = cleanName.lastIndexOf(".");
  return dotIndex >= 0 ? cleanName.slice(dotIndex).toLowerCase() : "";
}

function safeFileName(value: string) {
  return value
    .normalize("NFKD")
    .replace(/[^\w.-]+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "")
    .slice(0, 90);
}

async function withEvidenceUrls(
  adminClient: ReturnType<typeof createClient>,
  rows: Record<string, unknown>[]
) {
  return Promise.all(
    rows.map(async (row) => {
      const evidencePath =
        typeof row.evidence_path === "string" ? row.evidence_path : "";

      if (!evidencePath) {
        return { ...row, evidence_url: null };
      }

      const { data } = await adminClient.storage
        .from("budget-payment-evidence")
        .createSignedUrl(evidencePath, 60 * 60);

      return {
        ...row,
        evidence_url: data?.signedUrl ?? null,
      };
    })
  );
}

export async function GET(request: Request) {
  try {
    const auth = await requireActiveUser(request);
    if (!auth.ok) return auth.response;

    const { data, error } = await auth.adminClient
      .from("budget_payment_records")
      .select(PAYMENT_SELECT)
      .order("created_at", { ascending: false });

    if (error) {
      console.error("Load budget payments error:", error);
      return NextResponse.json(
        {
          ok: false,
          message:
            "ไม่สามารถโหลดประวัติการจ่ายได้ กรุณาตรวจว่ารัน SQL migration แล้ว",
        },
        { status: 500 }
      );
    }

    const payments = await withEvidenceUrls(
      auth.adminClient,
      (data ?? []) as Record<string, unknown>[]
    );

    return NextResponse.json({
      ok: true,
      payments,
      currentUser: {
        id: auth.profile.id,
        fullName: auth.profile.full_name,
        role: auth.profile.role,
        canFinance: auth.canFinance,
        canManageAll: auth.canManageAll,
      },
    });
  } catch (error) {
    console.error("Budget payments GET error:", error);
    return NextResponse.json(
      { ok: false, message: "เกิดข้อผิดพลาดระหว่างโหลดข้อมูลเบิกจ่าย" },
      { status: 500 }
    );
  }
}

export async function POST(request: Request) {
  try {
    const auth = await requireActiveUser(request);
    if (!auth.ok) return auth.response;

    if (!auth.canFinance) {
      return NextResponse.json(
        { ok: false, message: "เฉพาะเจ้าหน้าที่การเงิน ผู้ดูแลระบบ หรือผู้บริหารเท่านั้น" },
        { status: 403 }
      );
    }

    const form = await request.formData();
    const projectId = String(form.get("projectId") ?? "").trim();
    const projectName = String(form.get("projectName") ?? "").trim();
    const details = String(form.get("details") ?? "").trim();
    const paymentPeriod = String(form.get("paymentPeriod") ?? "").trim();
    const amount = Number(form.get("amount"));
    const note = String(form.get("note") ?? "").trim();
    const evidenceValue = form.get("evidence");
    const evidence =
      evidenceValue instanceof File && evidenceValue.size > 0
        ? evidenceValue
        : null;

    if (!projectId || !projectName) {
      return NextResponse.json(
        { ok: false, message: "ไม่พบโครงการที่ต้องการบันทึก" },
        { status: 400 }
      );
    }

    if (!details) {
      return NextResponse.json(
        { ok: false, message: "กรุณากรอกรายละเอียดการจ่าย" },
        { status: 400 }
      );
    }

    if (!Number.isFinite(amount) || amount <= 0) {
      return NextResponse.json(
        { ok: false, message: "จำนวนเงินไม่ถูกต้อง" },
        { status: 400 }
      );
    }

    let evidenceName: string | null = null;
    let evidencePath: string | null = null;

    if (evidence) {
      const maxSize = 10 * 1024 * 1024;
      const allowedTypes = new Set([
        "application/pdf",
        "image/png",
        "image/jpeg",
        "image/webp",
      ]);

      if (evidence.size > maxSize) {
        return NextResponse.json(
          { ok: false, message: "ไฟล์หลักฐานมีขนาดเกิน 10 MB" },
          { status: 400 }
        );
      }

      if (!allowedTypes.has(evidence.type)) {
        return NextResponse.json(
          { ok: false, message: "รองรับหลักฐาน PDF, PNG, JPG และ WEBP เท่านั้น" },
          { status: 400 }
        );
      }

      evidenceName = evidence.name;
      const extension = fileExtension(evidence.name);
      const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
      const fileBase =
        safeFileName(evidence.name.replace(extension, "")) || "evidence";
      evidencePath = `${projectId}/${timestamp}-${fileBase}${extension}`;

      const { error: uploadError } = await auth.adminClient.storage
        .from("budget-payment-evidence")
        .upload(evidencePath, evidence, {
          contentType: evidence.type,
          upsert: false,
        });

      if (uploadError) {
        console.error("Upload payment evidence error:", uploadError);
        return NextResponse.json(
          { ok: false, message: "อัปโหลดหลักฐานไม่สำเร็จ" },
          { status: 500 }
        );
      }
    }

    const now = new Date().toISOString();

    const { data, error } = await auth.adminClient
      .from("budget_payment_records")
      .insert({
        project_id: projectId,
        project_name: projectName,
        details,
        payment_period: paymentPeriod || null,
        amount,
        evidence_name: evidenceName,
        evidence_path: evidencePath,
        note: note || null,
        status: "active",
        created_at: now,
        created_by: auth.profile.id,
        created_by_name: auth.profile.full_name,
        updated_at: now,
      })
      .select(PAYMENT_SELECT)
      .single();

    if (error) {
      if (evidencePath) {
        await auth.adminClient.storage
          .from("budget-payment-evidence")
          .remove([evidencePath]);
      }

      console.error("Insert budget payment error:", error);
      return NextResponse.json(
        { ok: false, message: "บันทึกรายการจ่ายไม่สำเร็จ" },
        { status: 500 }
      );
    }

    const [payment] = await withEvidenceUrls(
      auth.adminClient,
      [data as Record<string, unknown>]
    );

    return NextResponse.json({
      ok: true,
      payment,
      message: "บันทึกรายการจ่ายเรียบร้อยแล้ว",
    });
  } catch (error) {
    console.error("Budget payments POST error:", error);
    return NextResponse.json(
      { ok: false, message: "เกิดข้อผิดพลาดระหว่างบันทึกรายการจ่าย" },
      { status: 500 }
    );
  }
}

export async function PATCH(request: Request) {
  try {
    const auth = await requireActiveUser(request);
    if (!auth.ok) return auth.response;

    if (!auth.canFinance) {
      return NextResponse.json(
        { ok: false, message: "คุณไม่มีสิทธิ์ยกเลิกรายการจ่าย" },
        { status: 403 }
      );
    }

    const body = (await request.json()) as {
      action?: unknown;
      paymentId?: unknown;
    };

    const action =
      typeof body.action === "string" ? body.action.trim() : "";
    const paymentId =
      typeof body.paymentId === "string" ? body.paymentId.trim() : "";

    if (action !== "cancel" || !paymentId) {
      return NextResponse.json(
        { ok: false, message: "คำสั่งไม่ถูกต้อง" },
        { status: 400 }
      );
    }

    const now = new Date().toISOString();

    const { data, error } = await auth.adminClient
      .from("budget_payment_records")
      .update({
        status: "cancelled",
        cancelled_at: now,
        cancelled_by: auth.profile.id,
        cancelled_by_name: auth.profile.full_name,
        updated_at: now,
      })
      .eq("id", paymentId)
      .eq("status", "active")
      .select(PAYMENT_SELECT)
      .single();

    if (error) {
      console.error("Cancel budget payment error:", error);
      return NextResponse.json(
        { ok: false, message: "ยกเลิกรายการจ่ายไม่สำเร็จ" },
        { status: 500 }
      );
    }

    const [payment] = await withEvidenceUrls(
      auth.adminClient,
      [data as Record<string, unknown>]
    );

    return NextResponse.json({
      ok: true,
      payment,
      message: "ยกเลิกรายการจ่ายเรียบร้อยแล้ว",
    });
  } catch (error) {
    console.error("Budget payments PATCH error:", error);
    return NextResponse.json(
      { ok: false, message: "เกิดข้อผิดพลาดระหว่างยกเลิกรายการ" },
      { status: 500 }
    );
  }
}
